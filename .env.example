OCR_DEVICE=auto
OCR_WORKERS=1
OCR_LOG_LEVEL=INFO
OCR_CACHE_ENABLED=true
OCR_RATE_LIMIT_ENABLED=true
OCR_API_KEYS=
OCR_CORS_ORIGINS=*
