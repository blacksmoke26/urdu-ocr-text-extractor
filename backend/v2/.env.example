# ─── Server ────────────────────────────────
OCR_HOST=0.0.0.0
OCR_PORT=8000
OCR_WORKERS=1
OCR_RELOAD=false

# ─── Device (auto | cpu | cuda) ───────────
OCR_DEVICE=auto

# ─── Detection Parameters ─────────────────
OCR_CONF_THRESHOLD=0.2
OCR_IMG_SIZE=1280
OCR_NMS=true

# ─── File Limits ──────────────────────────
OCR_MAX_FILE_SIZE_MB=50
OCR_MAX_BATCH_FILES=10

# ─── Caching ──────────────────────────────
OCR_CACHE_ENABLED=true
OCR_CACHE_TTL=3600

# ─── Rate Limiting ────────────────────────
OCR_RATE_LIMIT_ENABLED=true
OCR_RATE_LIMIT_REQUESTS=60
OCR_RATE_LIMIT_WINDOW=60

# ─── Authentication (comma-separated) ─────
OCR_API_KEYS=

# ─── PDF ──────────────────────────────────
OCR_PDF_DPI=300

# ─── Logging ──────────────────────────────
OCR_LOG_LEVEL=INFO

# ─── CORS ─────────────────────────────────
OCR_CORS_ORIGINS=*

# ─── Text Cleaning ────────────────────────
OCR_TEXT_CLEANING_ENABLED=true
