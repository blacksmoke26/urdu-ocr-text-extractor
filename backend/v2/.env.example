# ── Urdu OCR v2 — Environment Configuration ─────────────────────
# Copy this file to .env and adjust values as needed.

# ─── Server ───────────────────────────────────────────────────
OCR_HOST=localhost
OCR_PORT=8000
OCR_WORKERS=1
OCR_RELOAD=false

# ─── Device ───────────────────────────────────────────────────
OCR_DEVICE=auto        # auto | cpu | cuda

# ─── YOLO Detection ──────────────────────────────────────────
OCR_CONF_THRESHOLD=0.2    # Detection confidence threshold
OCR_IMG_SIZE=1280         # Input image size for YOLO
OCR_NMS=true              # Non-maximum suppression

# ─── Text Cleaning ───────────────────────────────────────────
OCR_TEXT_CLEANING_ENABLED=true

# ─── Urdu Text Auto-Correction ────────────────────────────────
URDUTEXT_AUTOCORRECT_ENABLED=true     # Enable auto-correction (recommended for production)
URDUTEXT_AUTOCORRECT_MODE=hybrid      # char | distance | hybrid

# ─── Spell Check Settings ──────────────────────────────────────
SPELL_CHECK_MAX_DISTANCE=2            # Max Levenshtein distance for candidate search
SPELL_CHECK_USE_WORD_FREQ=true        # Weight corrections by word frequency
URDU_DICT_DIR=../urdu-dict            # Path to urdu-dict directory (auto-detected if not set)

# ─── Caching ──────────────────────────────────────────────────
OCR_CACHE_ENABLED=true
OCR_CACHE_TTL=3600                # Cache TTL in seconds

# ─── Rate Limiting ────────────────────────────────────────────
OCR_RATE_LIMIT_ENABLED=true
OCR_RATE_LIMIT_REQUESTS=60
OCR_RATE_LIMIT_WINDOW=60

# ─── Authentication ──────────────────────────────────────────
# OCR_API_KEYS=your_api_key_here,another_key  # Comma-separated

# ─── PDF Settings ─────────────────────────────────────────────
OCR_PDF_DPI=300

# ─── Logging ──────────────────────────────────────────────────
OCR_LOG_LEVEL=INFO

# ─── CORS ─────────────────────────────────────────────────────
# OCR_CORS_ORIGINS=*   (comma-separated URLs or * for all)
